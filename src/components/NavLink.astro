---
const { href, label } = Astro.props;

const currentPath = Astro.url.pathname;

const isActive =
  currentPath === href || (href !== "/" && currentPath.startsWith(`${href}/`));

type Props = {
  label: string;
  href: string;
};
---

<a
  href={href}
  aria-current={isActive ? "page" : undefined}
  class="text-nav transition-colors duration-200 relative no-underline text-ink-mid hover:text-vermilion"
>
  {label}
</a>

<style>
  a[aria-current="page"] {
    color: var(--color-vermilion);
  }
  a[aria-current="page"]::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--color-vermilion);
  }
</style>
