---
import { Font } from "astro:assets";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "HeartSwept",
  description = "A curated anthology of haiku, free verse, and short stories — each piece a window into the space between breath and language.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <Font cssVariable="--font-lora" />
    <Font cssVariable="--font-cormorant" />
    <Font cssVariable="--font-noto" />
  </head>
  <body>
    <div class="site-wrapper">
      <Header />
      <slot />
      <Footer />
    </div>
  </body>
</html>

<style>
  .site-wrapper {
    position: relative;
    min-height: 100vh;
    z-index: 1;
    display: flex;
    flex-direction: column;
  }
  .site-wrapper::before {
    content: "";
    position: fixed;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(
      to bottom,
      var(--color-vermilion) 0%,
      transparent 100%
    );
    z-index: 100;
  }
</style>
